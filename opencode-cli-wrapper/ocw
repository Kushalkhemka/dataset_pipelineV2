#!/usr/bin/env python3
"""Thin headless CLI wrapper for opencode.

This wrapper intentionally does not add policy/restrictions. It forwards flags
directly to native `opencode run` / `opencode serve` and adds optional batch
execution for prompt datasets.
"""

from __future__ import annotations

import argparse
import csv
import json
import os
import shlex
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timezone
from pathlib import Path
from shutil import which
from threading import Event, Lock
from typing import Any, Iterable, Sequence


DEFAULT_BINARY = "opencode"
FULL_PERMISSION_CONFIG = {
    "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "doom_loop": "allow",
        "external_directory": "allow",
    },
    "experimental": {
        "batch_tool": True,
    },
}


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def eprint(message: str) -> None:
    print(message, file=sys.stderr)


def split_passthrough(args: Sequence[str]) -> tuple[list[str], list[str]]:
    items = list(args)
    if "--" not in items:
        return items, []
    index = items.index("--")
    return items[:index], items[index + 1 :]


def has_option(passthrough: Sequence[str], option: str) -> bool:
    return any(item == option or item.startswith(f"{option}=") for item in passthrough)


def resolve_binary(candidate: str) -> str:
    path = which(candidate)
    if path:
        return path
    raise SystemExit(f"error: unable to find '{candidate}' in PATH")


def run_command(command: Sequence[str], cwd: str | None = None, env: dict[str, str] | None = None) -> int:
    try:
        completed = subprocess.run(command, cwd=cwd, check=False, env=env)
        return completed.returncode
    except KeyboardInterrupt:
        return 130


def build_env(all_permissions: bool, xdg_data_home: str | None = None) -> dict[str, str]:
    env = dict(os.environ)
    if all_permissions:
        env["OPENCODE_CONFIG_CONTENT"] = json.dumps(FULL_PERMISSION_CONFIG, ensure_ascii=True)
    if xdg_data_home:
        env["XDG_DATA_HOME"] = xdg_data_home
    return env


def _safe_worker_key(value: str) -> str:
    cleaned = "".join(ch if ch.isalnum() or ch in "._-" else "_" for ch in value)
    cleaned = cleaned.strip("._-")
    return cleaned or "worker"


def resolve_xdg_data_home(
    command_name: str,
    explicit_xdg_data_home: str | None,
    isolate_db: bool,
    isolation_root: str,
    worker_id: str | None,
) -> str | None:
    if explicit_xdg_data_home and isolate_db:
        raise SystemExit("error: use either --xdg-data-home or --isolate-db, not both")

    if explicit_xdg_data_home:
        path = Path(explicit_xdg_data_home).expanduser()
        path.mkdir(parents=True, exist_ok=True)
        return str(path)

    if not isolate_db:
        return None

    worker_key = _safe_worker_key(worker_id or f"{command_name}-{os.getpid()}")
    root = Path(isolation_root).expanduser()
    path = root / worker_key
    path.mkdir(parents=True, exist_ok=True)
    return str(path)


def normalize_id(raw_value: str | None, prefix: str, mapping: dict[str, str], enable: bool) -> str | None:
    if raw_value is None:
        return None
    if not enable:
        return raw_value
    cached = mapping.get(raw_value)
    if cached is not None:
        return cached
    normalized = f"{prefix}{len(mapping) + 1}"
    mapping[raw_value] = normalized
    return normalized


def truncate_text(value: str, max_chars: int) -> str:
    if max_chars < 0:
        return value
    if len(value) <= max_chars:
        return value
    return f"{value[:max_chars]}...<TRUNCATED:{len(value)}>"


def sanitize_value(value: Any, max_chars: int) -> Any:
    if isinstance(value, str):
        return truncate_text(value, max_chars=max_chars)
    if isinstance(value, list):
        return [sanitize_value(item, max_chars=max_chars) for item in value]
    if isinstance(value, dict):
        return {
            key: sanitize_value(value[key], max_chars=max_chars)
            for key in sorted(value.keys(), key=str)
        }
    return value


def parse_prompt(prompt: str | None, use_stdin: bool, prompt_words: Sequence[str]) -> str:
    sources = int(prompt is not None) + int(use_stdin) + int(bool(prompt_words))
    if sources == 0:
        raise SystemExit("error: provide a prompt via --prompt, --stdin, or positional text")
    if sources > 1:
        raise SystemExit("error: use exactly one prompt source (--prompt, --stdin, or positional)")

    if prompt is not None:
        return prompt
    if use_stdin:
        text = sys.stdin.read().strip()
        if not text:
            raise SystemExit("error: stdin prompt is empty")
        return text
    return " ".join(prompt_words).strip()


def parse_text_prompts(path: Path) -> list[str]:
    prompts: list[str] = []
    for line in path.read_text(encoding="utf-8").splitlines():
        value = line.strip()
        if value:
            prompts.append(value)
    return prompts


def parse_jsonl_prompts(path: Path) -> list[str]:
    prompts: list[str] = []
    for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        raw = line.strip()
        if not raw:
            continue
        try:
            item = json.loads(raw)
        except json.JSONDecodeError as exc:
            raise SystemExit(f"error: invalid JSONL at line {line_number}: {exc}") from exc

        if isinstance(item, str):
            prompt = item
        elif isinstance(item, dict):
            prompt = item.get("prompt") or item.get("message") or item.get("input")
            if not isinstance(prompt, str) or not prompt.strip():
                raise SystemExit(
                    f"error: JSONL line {line_number} object must include non-empty "
                    f"'prompt' or 'message' string"
                )
        else:
            raise SystemExit(
                f"error: JSONL line {line_number} must be a string or object, got {type(item)}"
            )

        prompts.append(prompt.strip())

    return prompts


def parse_json_prompts(path: Path) -> list[str]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"error: invalid JSON file '{path}': {exc}") from exc

    if not isinstance(payload, list):
        raise SystemExit("error: JSON prompt file must be an array")

    prompts: list[str] = []
    for index, item in enumerate(payload):
        if isinstance(item, str) and item.strip():
            prompts.append(item.strip())
            continue
        if isinstance(item, dict):
            prompt = item.get("prompt") or item.get("message") or item.get("input")
            if isinstance(prompt, str) and prompt.strip():
                prompts.append(prompt.strip())
                continue
        raise SystemExit(
            "error: JSON array items must be non-empty strings or objects with "
            f"'prompt'/'message' (index {index})"
        )

    return prompts


def parse_csv_prompts(path: Path, csv_column: str | None = None, csv_template: str | None = None) -> list[str]:
    prompts: list[str] = []
    with path.open("r", encoding="utf-8", newline="") as handle:
        reader = csv.DictReader(handle)
        fieldnames = list(reader.fieldnames or [])
        if not fieldnames:
            raise SystemExit("error: CSV input must include a header row")

        default_column = csv_column
        if default_column is None and not csv_template:
            for candidate in ("prompt", "message", "input"):
                if candidate in fieldnames:
                    default_column = candidate
                    break
            if default_column is None and len(fieldnames) == 1:
                default_column = fieldnames[0]
            if default_column is None:
                raise SystemExit(
                    "error: CSV input needs --csv-column or --csv-template "
                    f"(available columns: {', '.join(fieldnames)})"
                )

        if default_column and default_column not in fieldnames:
            raise SystemExit(
                f"error: CSV column '{default_column}' not found "
                f"(available: {', '.join(fieldnames)})"
            )

        for row_number, row in enumerate(reader, start=2):
            row_data = {key: (value or "").strip() for key, value in row.items()}
            if csv_template:
                try:
                    prompt = csv_template.format(**row_data).strip()
                except KeyError as exc:
                    missing = str(exc).strip("'")
                    raise SystemExit(
                        f"error: CSV template references missing column '{missing}' "
                        f"at line {row_number}"
                    ) from exc
            else:
                prompt = row_data.get(default_column or "", "").strip()
            if prompt:
                prompts.append(prompt)

    return prompts


def load_prompts(
    input_path: str,
    csv_column: str | None = None,
    csv_template: str | None = None,
    offset: int = 0,
    limit: int | None = None,
) -> list[str]:
    if input_path == "-":
        prompts = [line.strip() for line in sys.stdin.read().splitlines() if line.strip()]
        if not prompts:
            raise SystemExit("error: no prompts found on stdin")
        if offset:
            prompts = prompts[offset:]
        if limit is not None:
            prompts = prompts[:limit]
        return prompts

    path = Path(input_path)
    if not path.exists():
        raise SystemExit(f"error: prompt file not found: {path}")

    suffix = path.suffix.lower()
    if suffix == ".jsonl":
        prompts = parse_jsonl_prompts(path)
    elif suffix == ".json":
        prompts = parse_json_prompts(path)
    elif suffix == ".csv":
        prompts = parse_csv_prompts(path, csv_column=csv_column, csv_template=csv_template)
    else:
        prompts = parse_text_prompts(path)

    if offset:
        prompts = prompts[offset:]
    if limit is not None:
        prompts = prompts[:limit]

    if not prompts:
        raise SystemExit("error: prompt file did not contain any usable prompts")
    return prompts


def build_worker_xdg_homes(
    workers: int,
    command_name: str,
    explicit_xdg_data_home: str | None,
    isolate_db: bool,
    isolation_root: str,
    worker_id: str | None,
) -> list[str | None]:
    if workers < 1:
        raise SystemExit("error: workers must be >= 1")

    if workers == 1:
        return [
            resolve_xdg_data_home(
                command_name=command_name,
                explicit_xdg_data_home=explicit_xdg_data_home,
                isolate_db=isolate_db,
                isolation_root=isolation_root,
                worker_id=worker_id,
            )
        ]

    root_base = Path((explicit_xdg_data_home or isolation_root)).expanduser()
    root_base.mkdir(parents=True, exist_ok=True)
    prefix = _safe_worker_key(worker_id or "worker")
    homes: list[str] = []
    for slot in range(workers):
        slot_name = f"{prefix}-{slot + 1:03d}"
        path = root_base / slot_name
        path.mkdir(parents=True, exist_ok=True)
        homes.append(str(path))
    return homes


def run_prompt_once(
    *,
    index: int,
    prompt: str,
    binary: str,
    cwd: str | None,
    base_passthrough: Sequence[str],
    all_permissions: bool,
    xdg_data_home: str | None,
    worker_slot: int,
) -> dict[str, object]:
    command = [binary, "run", prompt, *base_passthrough]
    started_monotonic = time.monotonic()
    started_at = now_iso()
    completed = subprocess.run(
        command,
        cwd=cwd,
        check=False,
        env=build_env(all_permissions=all_permissions, xdg_data_home=xdg_data_home),
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    ended_at = now_iso()
    duration_seconds = round(time.monotonic() - started_monotonic, 3)
    return {
        "index": index,
        "worker_slot": worker_slot,
        "xdg_data_home": xdg_data_home,
        "prompt": prompt,
        "command": command,
        "exit_code": completed.returncode,
        "started_at": started_at,
        "ended_at": ended_at,
        "duration_seconds": duration_seconds,
        "stdout": completed.stdout,
        "stderr": completed.stderr,
    }


def command_run(argv: Sequence[str]) -> int:
    wrapper_argv, passthrough_delimited = split_passthrough(argv)
    parser = argparse.ArgumentParser(
        prog="ocw run",
        description="Run one headless opencode prompt and forward all unknown flags to `opencode run`.",
    )
    parser.add_argument("-p", "--prompt", help="Prompt text")
    parser.add_argument("--stdin", action="store_true", help="Read prompt text from stdin")
    parser.add_argument("--binary", default=DEFAULT_BINARY, help="opencode binary path/name")
    parser.add_argument("--cwd", help="Working directory for opencode")
    parser.add_argument(
        "--xdg-data-home",
        help="Set XDG_DATA_HOME for this run (isolates opencode.db location)",
    )
    parser.add_argument(
        "--isolate-db",
        action="store_true",
        help="Create/use isolated XDG_DATA_HOME under --isolation-root",
    )
    parser.add_argument(
        "--isolation-root",
        default="/tmp/ocw_xdg",
        help="Root directory for isolated XDG_DATA_HOME paths",
    )
    parser.add_argument(
        "--worker-id",
        help="Worker/shard id used with --isolate-db (e.g., shard-01)",
    )
    parser.add_argument("--json-events", action="store_true", help="Force --format json")
    parser.add_argument("--print-command", action="store_true", help="Print the command before running")
    parser.add_argument(
        "--respect-opencode-permissions",
        action="store_true",
        help="Do not inject full-allow permissions (default injects full allow)",
    )
    parser.add_argument("prompt_words", nargs="*", help="Prompt words (alternative to --prompt)")
    args, passthrough_unknown = parser.parse_known_args(wrapper_argv)
    passthrough = [*passthrough_unknown, *passthrough_delimited]

    prompt = parse_prompt(args.prompt, args.stdin, args.prompt_words)
    binary = resolve_binary(args.binary)
    xdg_data_home = resolve_xdg_data_home(
        command_name="run",
        explicit_xdg_data_home=args.xdg_data_home,
        isolate_db=args.isolate_db,
        isolation_root=args.isolation_root,
        worker_id=args.worker_id,
    )

    command = [binary, "run", prompt]
    if args.json_events and not has_option(passthrough, "--format"):
        command.extend(["--format", "json"])
    command.extend(passthrough)

    if args.print_command:
        eprint(f"$ {shlex.join(command)}")
    if xdg_data_home:
        eprint(f"[ocw] using XDG_DATA_HOME={xdg_data_home}")

    return run_command(
        command,
        cwd=args.cwd,
        env=build_env(
            all_permissions=not args.respect_opencode_permissions,
            xdg_data_home=xdg_data_home,
        ),
    )


def command_serve(argv: Sequence[str]) -> int:
    wrapper_argv, passthrough_delimited = split_passthrough(argv)
    parser = argparse.ArgumentParser(
        prog="ocw serve",
        description="Start a headless opencode server, forwarding all flags to `opencode serve`.",
    )
    parser.add_argument("--binary", default=DEFAULT_BINARY, help="opencode binary path/name")
    parser.add_argument("--cwd", help="Working directory for opencode")
    parser.add_argument(
        "--xdg-data-home",
        help="Set XDG_DATA_HOME for this server (isolates opencode.db location)",
    )
    parser.add_argument(
        "--isolate-db",
        action="store_true",
        help="Create/use isolated XDG_DATA_HOME under --isolation-root",
    )
    parser.add_argument(
        "--isolation-root",
        default="/tmp/ocw_xdg",
        help="Root directory for isolated XDG_DATA_HOME paths",
    )
    parser.add_argument(
        "--worker-id",
        help="Worker/shard id used with --isolate-db (e.g., shard-01)",
    )
    parser.add_argument("--print-command", action="store_true", help="Print the command before running")
    parser.add_argument(
        "--respect-opencode-permissions",
        action="store_true",
        help="Do not inject full-allow permissions (default injects full allow)",
    )
    args, passthrough_unknown = parser.parse_known_args(wrapper_argv)
    passthrough = [*passthrough_unknown, *passthrough_delimited]

    binary = resolve_binary(args.binary)
    xdg_data_home = resolve_xdg_data_home(
